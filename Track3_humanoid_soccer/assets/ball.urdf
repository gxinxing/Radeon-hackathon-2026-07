<?xml version="1.0"?>
<!-- Soccer ball: pure-sphere rigid body, no mesh file required. -->
<robot name="soccer_ball">
  <link name="ball">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.45e-5" iyy="1.45e-5" izz="1.45e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <collision>
      <geometry>
        <sphere radius="0.11"/>
      </geometry>
    </collision>
    <visual>
      <geometry>
        <sphere radius="0.11"/>
      </geometry>
      <material name="ball">
        <color rgba="1.0 0.85 0.0 1.0"/>
      </material>
    </visual>
  </link>
</robot>
