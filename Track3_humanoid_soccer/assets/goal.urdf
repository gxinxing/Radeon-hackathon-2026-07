<?xml version="1.0"?>
<!-- Goal-line marker: a thin flat box so the demo video shows where to score. -->
<robot name="goal_marker">
  <link name="goal">
    <collision>
      <geometry>
        <box size="0.1 2.6 0.06"/>
      </geometry>
    </collision>
    <visual>
      <geometry>
        <box size="0.1 2.6 0.06"/>
      </geometry>
      <material name="goal">
        <color rgba="0.1 0.6 1.0 0.5"/>
      </material>
    </visual>
  </link>
</robot>
